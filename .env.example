# Skopiuj do .env i uzupełnij wartości
# cp .env.example .env

# ── Wspólny sekret service-to-service A2A (MVP — patrz PRD sekcja 15) ────────
# Ta sama wartość musi być znana każdemu agentowi w środowisku.
A2A_TOKEN=change_me

# ── Tożsamość wywołań orchestratora ──────────────────────────────────────────
TENANT_ID=portal-ai
APP_ID=portal-ai

# ── Publiczne URL-e w Agent Card (muszą wskazywać na nginx, nie na docker-net) ─
PUBLIC_BASE_URL_ORCHESTRATOR=https://portal-ai.local/agents/orchestrator-agent
PUBLIC_BASE_URL_RAG=https://portal-ai.local/agents/rag-agent

# ── Porty hosta (sprawdź dostępność na 10.112.32.19 przed wdrożeniem!) ────────
AGENT_REGISTRY_PORT=8041
ORCHESTRATOR_PORT=8042
RAG_AGENT_PORT=8043

# ── PostgreSQL (TaskManager) ──────────────────────────────────────────────────
POSTGRES_PASSWORD=portal_ai_password_change_me

# ── Istniejący serwis RAG (rag-module) wołany przez rag-agent jako narzędzie ──
# Pozostaw puste, żeby rag-agent odpowiadał stubem (np. w testach offline).
RAG_BACKEND_URL=http://10.112.32.19:8011/rag/chat
RAG_TENANT_ID=portal-ai
RAG_APP_ID=a2a-rag-agent
RAG_KNOWLEDGE_BASE_ID=default

# ── JFrog (opcjonalnie — dla podmiany obrazów Docker) ─────────────────────────
# JFROG_REGISTRY=jfrog.company.local
